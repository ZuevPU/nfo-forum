{
  "name": "backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed": "tsx src/scripts/seed.ts",
    "seed:dedupe": "tsx src/scripts/seed-reset.ts dedupe",
    "seed:reset": "tsx src/scripts/seed-reset.ts reset && tsx src/scripts/seed.ts",
    "promote-admin": "tsx src/scripts/promote-admin.ts",
    "push:diagnostics": "tsx src/scripts/push-diagnostics.ts",
    "db:migrate": "node scripts/apply-pending-migrations.mjs",
    "db:seed-mascot": "node scripts/seed-push-mascot.mjs",
    "db:close-test-questions": "node scripts/close-test-questions.mjs",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.39.3",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "pg": "^8.13.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.11",
    "drizzle-kit": "^0.30.4",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
