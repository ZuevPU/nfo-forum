# Production environment — copy to .env on server (never commit secrets)

DATABASE_URL=postgresql://user:pass@host:5432/postgres?sslmode=require
PORT=3001
NODE_ENV=production
TZ=Europe/Moscow

# Frontend build-time (Vite)
VITE_API_URL=https://nfo-backend-production.up.railway.app

# Backend CORS — VK launcher + VK Hosting (*.vk-apps.com allowed in code)
FRONTEND_ORIGIN=https://vk.com

# VK Mini App
VK_APP_ID=54627015
VK_APP_SECRET=your_vk_app_secret
VK_GROUP_TOKEN=your_vk_group_token
VK_GROUP_ID=your_group_id

# Cron jobs authentication
CRON_SECRET=change_to_random_32_char_secret

# Dev only — set false in production
SKIP_VK_SIGN=false
