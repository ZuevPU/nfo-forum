{
  "name": "nfo-forum",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "start": "node backend/dist/index.js",
    "build": "npm run build -w backend",
    "dev:backend": "npm run dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "tunnel:frontend": "npm run tunnel -w frontend",
    "tunnel:vk": "powershell -File deploy/run-vk-tunnel.ps1",
    "tunnel:local": "powershell -File deploy/run-local-tunnel.ps1",
    "tunnel:diagnose": "node deploy/diagnose-vk-tunnel.mjs",
    "build:backend": "npm run build -w backend",
    "build:frontend": "npm run build -w frontend",
    "seed:dedupe": "npm run seed:dedupe -w backend",
    "seed:reset": "npm run seed:reset -w backend",
    "smoke-test": "bash scripts/smoke-test.sh",
    "smoke-test:ps1": "powershell -File scripts/smoke-test.ps1",
    "vk-checklist:ps1": "powershell -File scripts/vk-checklist.ps1",
    "build:frontend:prod": "powershell -File deploy/build-frontend.ps1",
    "deploy:frontend:timeweb": "powershell -File deploy/deploy-frontend-timeweb.ps1",
    "package:vk": "powershell -File deploy/package-vk-frontend.ps1",
    "deploy:vk": "powershell -File deploy/deploy-vk-hosting.ps1 -Environment dev",
    "deploy:vk:dev": "powershell -File deploy/deploy-vk-hosting.ps1 -Environment dev",
    "deploy:vk:prod": "powershell -File deploy/deploy-vk-hosting.ps1 -Environment production",
    "deploy:vk:curl": "node deploy/deploy-vk-curl.mjs",
    "deploy:backend": "powershell -File deploy/deploy-backend-timeweb.ps1",
    "verify:prod": "powershell -File deploy/verify-production.ps1",
    "verify:plan": "node scripts/plan-smoke.mjs",
    "db:seed-mascot": "node backend/scripts/seed-push-mascot.mjs",
    "test:exports": "npm run build -w backend && node backend/scripts/verify-exports.mjs"
  }
}
